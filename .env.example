# Lumia frontend configuration.
# Copy this file to `.env` and point it at your running backend / CDN.

# REST API root. Endpoints live at the root (e.g. /users, /gallery, /anime/...).
NUXT_PUBLIC_API_BASE_URL=http://localhost:8787

# better-auth mount point (usually `${API_BASE_URL}/api/auth`).
NUXT_PUBLIC_AUTH_BASE_URL=http://localhost:8787/api/auth

# Public CDN base for uploaded images. A storage key resolves to
# `${BASE_CDN_URL}/${storageKey}`. In dev this is the S3-compatible bucket
# (e.g. SeaweedFS); in production it is the Cloudflare R2 public URL.
NUXT_PUBLIC_BASE_CDN_URL=http://localhost:8333/lumia
